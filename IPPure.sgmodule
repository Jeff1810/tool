#!name=IPPure
#!desc=ip纯净度检测（IPPure）
#!category=网络检测
#!arguments=Proxy:Global,MarkIP:false
#!arguments-desc=Proxy: MarkIP: IP 打码(true/false),默认 false

[Rule]
# 确保检测请求走选定的代理策略
DOMAIN-SUFFIX,ippure.com,{{{Proxy}}}

[Panel]
IPPure = script-name=IPPure, title=IPPure, content=刷新中…, style=info, update-interval=-1

[Script]
IPPure = type=generic, timeout=10, argument={{{MarkIP}}}, script-path=https://raw.githubusercontent.com/Jeff1810/tool/refs/heads/master/IPPure.js